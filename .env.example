# Supabase - Required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase - Required for bypass auth (admin API)
# Get this from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Domain & Cookie Configuration — Required for multi-domain support
# Set this to the root domain so session cookies work across both qrhisab.com and app.qrhisab.com
COOKIE_DOMAIN=.qrhisab.com
# Canonical site URL used in SMS links, eSewa callbacks, and signout redirects
NEXT_PUBLIC_SITE_URL=https://app.qrhisab.com

# Aakash SMS Gateway — Required for OTP and payment reminders
# Get your token from: https://aakashsms.com/admin/public/user/dashboard
AAKASH_SMS_TOKEN=your-aakash-sms-token-here
